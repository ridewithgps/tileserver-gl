# Path to tileserver data directory (local/Docker only)
# Must contain: config.json, mbtiles/, fonts/, sprites/, styles/
# Omit for remote/production — dynamic loading tests will skip
TEST_DATA_DIR=/media/jeremy/bigboy/tile-splitter/tile-server

# Tileserver URL — all tests hit this endpoint
# For local Docker: http://localhost:8080
# For production:   https://tiles.example.com
TILESERVER_URL=http://localhost:8080

# Optional: public URL for tileserver (e.g. ngrok tunnel)
# PUBLIC_URL=https://your-tunnel.ngrok.app
