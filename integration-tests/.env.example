# Path to extracted test data directory
# Must contain: config.json, mbtiles/, fonts/, sprites/, styles/
TEST_DATA_DIR=/media/jeremy/bigboy/tile-splitter/tile-server

# Port to expose tileserver on (default 8080)
TILESERVER_PORT=8080

# Test environment: "local" (docker compose) or "staged" (remote server)
# Controls whether docker-dependent checks (restart detection) run.
TEST_ENV=local

# Optional: public URL for tileserver (e.g. ngrok tunnel)
# PUBLIC_URL=https://your-tunnel.ngrok.app
